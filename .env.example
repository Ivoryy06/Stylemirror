# StyleMirror — Hybrid LLM mode
#
# Offline / localhost → Ollama (no key needed)
# Online (website)   → user picks ChatGPT or Gemini in the UI

# Ollama (default, offline)
LLM_MODEL=llama3
OPENAI_BASE_URL=http://localhost:11434/v1

# Online providers (set on your server or let users supply keys in the UI)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Frontend: set to your deployed backend URL
VITE_API_BASE=http://localhost:8787
