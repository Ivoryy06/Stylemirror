# StyleMirror uses Ollama by default — no API key needed.
# Just install Ollama (https://ollama.com) and run: ollama pull llama3

# Optional: override the Ollama model
LLM_MODEL=llama3

# Optional: if Ollama runs on a different host/port
OPENAI_BASE_URL=http://localhost:11434/v1

# Frontend: set this to your deployed backend URL
VITE_API_BASE=http://localhost:8787
