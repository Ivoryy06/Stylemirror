# Copy to .env and fill in your values

# Required: your LLM API key
OPENAI_API_KEY=sk-...

# Optional: swap to another OpenAI-compatible provider
# Groq:    OPENAI_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama3-8b-8192
# Mistral: OPENAI_BASE_URL=https://api.mistral.ai/v1       LLM_MODEL=mistral-small-latest
# Ollama:  OPENAI_BASE_URL=http://localhost:11434/v1        LLM_MODEL=llama3
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Frontend: set this to your deployed backend URL
VITE_API_BASE=https://your-backend.railway.app
